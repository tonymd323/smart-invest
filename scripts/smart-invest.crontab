CRON_TZ=Asia/Shanghai
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=Asia/Shanghai
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
# 投资系统 Pipeline（晚间扫描）
30 20 * * 1-5 cd /app && /usr/local/bin/python3 scripts/run_pipeline.py --window 6h >> data/logs/pipeline_cron.log 2>&1
# 投资系统回调扫描（盘后回调买入信号）
15 15 * * 1-5 cd /app && /usr/local/bin/python3 -c "from core.analyzer import PullbackAnalyzer; pa = PullbackAnalyzer(db_path='data/smart_invest.db'); pa.scan()" >> data/logs/pullback_cron.log 2>&1
# 投资系统回测回填（每周日）
0 10 * * 0 cd /app && /usr/local/bin/python3 scripts/btiq_backfill.py >> data/logs/backtest_cron.log 2>&1
# 盘后全量扫描
35 15 * * 1-5 cd /app && /usr/local/bin/python3 scripts/run_pipeline.py --window 6h --max-stocks 300 >> data/logs/pipeline_eod.log 2>&1
# 晚间补充扫描
10 22 * * 0 cd /app && /usr/local/bin/python3 scripts/run_pipeline.py --window 6h >> data/logs/pipeline_cron.log 2>&1
# A股晚报（板块轮动+指数概览）
5 18 * * 1-5 cd /app && /usr/local/bin/python3 -m scripts.push_evening_report >> data/logs/evening_report.log 2>&1
# 超跌监控（盘中每10分钟）
*/10 9-14 * * 1-5 cd /app && /usr/local/bin/python3 scripts/run_with_log.py btiq_monitor 超跌监控 -- python3 scripts/btiq_monitor.py >> data/logs/btiq_monitor.log 2>&1
# A股早报（指数+板块+全球资产+LLM分析）
3 7 * * 1-5 cd /app && TZ=Asia/Shanghai /usr/local/bin/python3 -m scripts.push_morning_report >> data/logs/morning_report.log 2>&1
# PE/PB 数据补数（每日收盘后）
5 16 * * 1-5 cd /root/.openclaw/workspace/smart-invest && python3 scripts/fill_pe_pb.py >> data/logs/fill_pe_pb.log 2>&1
